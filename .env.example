# FarmIQ Environment Variables
# Copy to .env and fill in your values

# Required for AI Crop Doctor (Gemini Vision)
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default: gemini-2.0-flash)
# Use gemini-1.5-flash if 2.0 is unavailable in your region
# GEMINI_MODEL=gemini-1.5-flash

PORT=3001

# For production: your deployed app URL (Vercel, etc.)
# Used for SEO meta tags, sitemap, canonical URLs
# VITE_APP_URL=https://farmiq.app
