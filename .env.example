# FarmIQ Environment Variables
# Copy to .env and fill in your values

# Required for AI Crop Doctor (Gemini Vision)
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default: gemini-3-flash)
# gemini-3.1-flash-lite = cheapest/fastest; gemini-3.1-pro = most advanced
# GEMINI_MODEL=gemini-3.1-flash-lite

PORT=3001

# For production (Vercel): backend API URL — REQUIRED when frontend is on Vercel
# Get this from your Render service (e.g. https://farmiq-7qet.onrender.com)
VITE_API_URL=

# For production: your deployed frontend URL
# Used for SEO meta tags, sitemap, canonical URLs
# VITE_APP_URL=https://farmiq.app
